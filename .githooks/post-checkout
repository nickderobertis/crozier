#!/usr/bin/env bash
# Keep Cargo targets per-worktree while sharing rustc results through sccache.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
config_dir="$repo_root/.cargo"
config="$config_dir/config.toml"
marker="# Generated by .githooks/post-checkout; rerun that hook to refresh."

# Never replace configuration the developer owns.
if [ -f "$config" ] && ! grep -Fqx "$marker" "$config"; then
  exit 0
fi

# Remove only configuration generated by this hook if sccache has since gone
# away. With no generated config this is a strict no-op, leaving Cargo's normal
# compiler invocation untouched.
if ! command -v sccache >/dev/null 2>&1; then
  [ ! -f "$config" ] || rm "$config"
  exit 0
fi

git_common_dir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || exit 0

if [ -n "${ORCHESTRATOR_CACHE_DIR:-}" ]; then
  cache_dir="$ORCHESTRATOR_CACHE_DIR/sccache"
else
  cache_dir="$git_common_dir/crozier-cache/sccache"
fi

mkdir -p "$config_dir" "$cache_dir"
tmp_config="$config.tmp.$$"
trap 'rm -f "$tmp_config"' EXIT
{
  printf '%s\n' "$marker"
  printf '[build]\n'
  # Use PATH resolution at build time. In particular, Git Bash's `command -v`
  # can produce a POSIX path that native Windows Cargo cannot execute.
  printf 'rustc-wrapper = "sccache"\n\n'
  printf '[env]\n'
  printf 'SCCACHE_DIR = { value = "%s", force = true }\n' "$cache_dir"
} >"$tmp_config"
mv "$tmp_config" "$config"
trap - EXIT
