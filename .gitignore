/target
**/*.rs.bk
*.pdb

# llmlint / oneharness local state
.oneharness/
llmlint.buildout.yml

# gh-secrets local sync state (machine-local hashes; the manifest is committed,
# this is not). See gh-secrets.json.
/.gh-secrets-state.json

# Scratch output from local generation runs
/out
/.crozier-tmp

# Machine-local corpus cache: `link-ok` OpenAPI specs fetched by
# scripts/fetch-corpus.sh for the byte-match corpus tests. The specs are
# link-only by policy (only Fern's generated goldens are vendored, under
# tests/fixtures/), so they are never committed — CI re-fetches them.
/.local

# screencomp visual-docs: the committed digest baseline (shots/baseline/) and the
# README images (docs/screenshots/) ARE tracked; the regenerated capture trees and
# the rendered gallery are throwaway.
/shots/current
/shots/review
/site

# maturin / Python packaging build output (wheels + sdist)
/dist

# Python bytecode caches (the runtime wire tests import generated SDKs; a stray
# non-sandboxed run can drop these next to the imported modules / fixtures)
__pycache__/
*.pyc
.pytest_cache/
